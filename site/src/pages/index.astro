---
const pageTitle = 'Azure DevOps Demo Generator | Create Template-Populated Azure DevOps Projects';
const pageDescription =
	'Azure DevOps Demo Generator creates complete Azure DevOps projects from templates with repos, work items, iterations, pipelines, releases, dashboards, and service connections for demos, labs, and onboarding.';
const keywords = [
	'Azure DevOps Demo Generator',
	'Azure DevOps project templates',
	'Azure DevOps automation',
	'Azure DevOps REST API samples',
	'DevOps training labs',
	'work items and pipelines bootstrap',
];
const repositoryUrl = 'https://github.com/microsoft/AzureDevOpsDemoGenerator';
const docsUrl = `${repositoryUrl}/tree/main/docs`;
const serviceUrl = 'https://azuredevopsdemogenerator.azurewebsites.net/';
const basePath = import.meta.env.BASE_URL;
const site = Astro.site ?? new URL('https://example.com');
const canonicalUrl = new URL(Astro.url.pathname, site).toString();
const socialImageUrl = new URL(`${basePath}social-card.png`, site).toString();

const softwareSchema = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: 'Azure DevOps Demo Generator',
	applicationCategory: 'DeveloperApplication',
	operatingSystem: 'Web',
	url: canonicalUrl,
	codeRepository: repositoryUrl,
	description: pageDescription,
	offers: {
		'@type': 'Offer',
		price: '0',
		priceCurrency: 'USD',
	},
	publisher: {
		'@type': 'Organization',
		name: 'Microsoft',
	},
};

const websiteSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: 'Azure DevOps Demo Generator',
	url: canonicalUrl,
	description: pageDescription,
};
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={pageDescription} />
		<meta name="keywords" content={keywords.join(', ')} />
		<meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
		<link rel="canonical" href={canonicalUrl} />

		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Azure DevOps Demo Generator" />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={pageDescription} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={socialImageUrl} />
		<meta property="og:image:alt" content="Azure DevOps Demo Generator preview image" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={pageDescription} />
		<meta name="twitter:image" content={socialImageUrl} />

		<link rel="icon" type="image/svg+xml" href={`${basePath}favicon.svg`} />
		<link rel="icon" href={`${basePath}favicon.ico`} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,700&display=swap"
			rel="stylesheet"
		/>

		<title>{pageTitle}</title>

		<script type="application/ld+json" set:html={JSON.stringify(softwareSchema)}></script>
		<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)}></script>
	</head>
	<body>
		<main>
			<p class="eyebrow">Azure DevOps • Demo Automation • Template Provisioning</p>
			<h1>Azure DevOps Demo Generator</h1>
			<p class="lead">
				Create complete Azure DevOps projects preloaded with source repositories, work items,
				iterations, boards, pipelines, releases, test assets, and dashboards from reusable templates.
			</p>

			<section>
				<h2>What It Is For</h2>
				<p>
					This project accelerates demos, hands-on labs, and training by provisioning realistic Azure DevOps
					environments in minutes. Teams also use it as a reference implementation for Azure DevOps REST API
					automation and repeatable project bootstrapping.
				</p>
			</section>

			<section>
				<h2>Core Capabilities</h2>
				<ul>
					<li>Scaffold new Azure DevOps projects from curated templates.</li>
					<li>Populate boards, queries, iterations, and work items automatically.</li>
					<li>Import source code and configure CI/CD definitions.</li>
					<li>Create service endpoints, dashboards, wikis, and test plans.</li>
				</ul>
			</section>

			<section>
				<h2>Useful Links</h2>
				<ul>
					<li><a href={serviceUrl}>Hosted Demo Generator Service</a></li>
					<li><a href={repositoryUrl}>GitHub Repository</a></li>
					<li><a href={docsUrl}>Documentation</a></li>
				</ul>
			</section>
		</main>
	</body>
</html>

<style>
	:root {
		--bg: #f3f5eb;
		--card: #fffefa;
		--ink: #101317;
		--muted: #475366;
		--line: #d0d8c5;
		--accent: #005c84;
		--accent-soft: #d9edf6;
	}

	* {
		box-sizing: border-box;
	}

	body {
		margin: 0;
		min-height: 100vh;
		font-family: 'Source Serif 4', Georgia, serif;
		color: var(--ink);
		background:
			radial-gradient(circle at 10% 0%, #dff6e8 0%, rgba(223, 246, 232, 0) 38%),
			radial-gradient(circle at 90% 90%, #d9edf6 0%, rgba(217, 237, 246, 0) 34%),
			var(--bg);
	}

	main {
		width: min(920px, calc(100% - 2rem));
		margin: 3rem auto;
		padding: 2rem;
		border: 1px solid var(--line);
		border-radius: 16px;
		background: linear-gradient(145deg, var(--card), #f7f8f3);
		box-shadow: 0 18px 45px rgba(16, 19, 23, 0.08);
	}

	.eyebrow,
	h1,
	h2 {
		font-family: 'Space Grotesk', system-ui, sans-serif;
	}

	.eyebrow {
		margin: 0;
		color: var(--accent);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-size: 0.78rem;
		font-weight: 700;
	}

	h1 {
		margin: 0.5rem 0 1rem;
		font-size: clamp(2rem, 3.5vw, 3rem);
		line-height: 1.1;
	}

	h2 {
		margin: 2rem 0 0.5rem;
		font-size: clamp(1.2rem, 2vw, 1.55rem);
	}

	p,
	li {
		font-size: 1.08rem;
		line-height: 1.65;
		color: var(--muted);
	}

	.lead {
		font-size: 1.2rem;
		max-width: 68ch;
		color: #20324a;
	}

	ul {
		padding-left: 1.2rem;
		margin: 0.35rem 0 0;
	}

	a {
		color: var(--accent);
		text-decoration: underline;
		text-decoration-color: rgba(0, 92, 132, 0.35);
		text-underline-offset: 0.2em;
	}

	a:hover {
		text-decoration-color: var(--accent);
	}

	@media (max-width: 700px) {
		main {
			margin: 1rem auto;
			padding: 1.25rem;
			border-radius: 12px;
		}
	}
</style>
