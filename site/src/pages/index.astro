---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import FeatureCard from '../components/FeatureCard.astro';

const pageTitle = 'Azure DevOps Demo Generator | High-Speed Environment Provisioning';
const pageDescription = 'Empower your teams with instant, production-ready Azure DevOps environments. Professional templates for labs, demos, and rapid onboarding.';
---

<Layout title={pageTitle} description={pageDescription}>
	<Navbar />
	
	<main>
		<!-- Hero Section -->
		<section class="hero text-center">
			<div class="hero-content animate-in">
				<p class="eyebrow">Meet the Future of DevOps Labs</p>
				<h1>The ultimate engine for <br/> <span class="gradient-text">Azure DevOps lab data automation.</span></h1>
				<p class="lead">CLI-first toolkit for generating Azure DevOps demo projects from curated templates. Self-contained, portable, and ready for automation.</p>
				 <div class="hero-actions">
					<a href="https://github.com/phenixita/AzureDevOpsDemoGenerator/releases" class="btn btn-primary">Download AzdoGenCli.exe</a>
					<a href="#how-it-works" class="btn btn-secondary">Learn More</a>
				 </div>
			</div> 
		</section>

		<!-- The Why Section -->
		<section class="why-section bg-alt" id="features">
			<div class="text-center section-header animate-in">
				<h2>One tool. <br/> Infinite possibilities.</h2>
				<p>Accelerate your workflow with curated templates and robust automation.</p>
			</div>
			<div class="features-grid">
				<FeatureCard 
					title="Self-Contained EXE" 
					description="Distributed as a single file. No .NET runtime or SDK installation required on Windows. Just download and run.">
					<svg slot="icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><path d="M9 3v18M15 3v18M3 9h18M3 15h18"></path></svg>
				</FeatureCard>

				<FeatureCard 
					title="Instant Scaffolding" 
					description="Provision new Azure DevOps projects from a wide range of curated industry templates like eShopOnWeb or SmartHotel360.">
					<svg slot="icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path></svg>
				</FeatureCard>
				
				<FeatureCard 
					title="Smart Authentication" 
					description="Seamless OAuth browser sign-in for interactive use, or PAT tokens for non-interactive automation and CI.">
					<svg slot="icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
				</FeatureCard>
				
				<FeatureCard 
					title="Rich Content" 
					description="Populate repos, boards, pipelines, and dashboards automatically, reflecting industry best practices.">
					<svg slot="icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="9" y1="3" x2="9" y2="21"></line></svg>
				</FeatureCard>
			</div>
		</section>

		<!-- How it works Section -->
		<section class="how-it-works" id="how-it-works">
			<div class="section-header animate-in">
				<h2>How it works.</h2>
				<p>From zero to a full demo environment in seconds.</p>
			</div>
			<div class="steps-container">
				<div class="step animate-in">
					<div class="step-num">01</div>
					<div class="step-content">
						<h3>Download & Discover</h3>
						<p>Get the latest <code>AzdoGenCli.exe</code> and list available templates using <code>--list-templates</code>.</p>
					</div>
				</div>
				<div class="step animate-in">
					<div class="step-num">02</div>
					<div class="step-content">
						<h3>Authenticate</h3>
						<p>Login via browser (OAuth) automatically, or provide a Personal Access Token (PAT) for automation.</p>
					</div>
				</div>
				<div class="step animate-in">
					<div class="step-num">03</div>
					<div class="step-content">
						<h3>Provision</h3>
						<p>Run the CLI with your organization, project name, and template. Watch it build your environment.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- CLI Section -->
		<section class="cli-section text-center animate-in">
			<div class="cli-content">
				<h2>Terminal-First Experience</h2>
				<p>The new AzDoGen CLI brings the power of the demo generator to your automation pipelines.</p>
				<div class="terminal-mockup">
					<div class="terminal-body">
						<code>.\AzdoGenCli.exe --org myorg --project "Lab01" --template eShopOnWeb</code>
						<code>[INFO] Authenticating via OAuth browser sign-in...</code>
						<code>[INFO] Creating project: Lab01</code>
						<code>[INFO] Applying template: eShopOnWeb</code>
						<code>[INFO] [✓] Importing Repositories...</code>
						<code>[INFO] [✓] Configuring Pipelines...</code>
						<code>[INFO] Success! Project URL: https://dev.azure.com/myorg/Lab01</code>
					</div>
				</div>
			</div>
		</section>

		<!-- Auth Modes Section -->
		<section class="auth-section bg-alt">
			<div class="max-w-4xl mx-auto text-center animate-in">
				<h2>Built for Humans and Bots</h2>
				<p class="mb-12">Choose the authentication mode that fits your workflow.</p>
				<div class="features-grid">
					<div class="card p-6 text-left">
						<h3 class="text-xl font-bold mb-4">OAuth (Default)</h3>
						<p class="text-secondary">Best for quick interactive local usage. The CLI opens a browser for you to sign in securely.</p>
					</div>
					<div class="card p-6 text-left">
						<h3 class="text-xl font-bold mb-4">PAT (Automation)</h3>
						<p class="text-secondary">Best for CI/CD, scripts, and non-interactive runs. Pass it via <code>--pat</code> or <code>AZURE_DEVOPS_PAT</code> env var.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA Section -->
		<section class="cta-section text-center animate-in">
			<h2>Ready to transform your labs?</h2>
			<div class="mt-8">
				<a href="https://github.com/phenixita/AzureDevOpsDemoGenerator" class="btn btn-primary">Star on GitHub</a>
			</div>
		</section>
	</main>

	<footer class="footer">
		<div class="footer-container">
			<div class="footer-info">
				<p>© {new Date().getFullYear()} Azure DevOps Demo Generator</p>
				<p>A community project maintained on GitHub.</p>
			</div>
			<div class="footer-links">
				<a href="https://github.com/phenixita/AzureDevOpsDemoGenerator">Source Code</a>
				<a href="https://github.com/phenixita/AzureDevOpsDemoGenerator/blob/main/LICENSE">License</a>
			</div>
		</div>
	</footer>
</Layout>

<style>
	.hero {
		padding-top: 100px;
		padding-bottom: 60px;
	}

	.eyebrow {
		font-weight: 600;
		color: var(--text-secondary);
		margin-bottom: 12px;
		font-size: 21px;
	}

	h1 {
		font-size: clamp(40px, 8vw, 80px);
		line-height: 1.05;
		margin-bottom: 24px;
		color: #1d1d1f;
	}

	.gradient-text {
		background: linear-gradient(90deg, #0071e3, #00b4d8);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	.lead {
		font-size: clamp(21px, 2vw, 24px);
		max-width: 800px;
		margin: 0 auto 40px;
	}

	.hero-actions {
		display: flex;
		gap: 20px;
		justify-content: center;
		margin-bottom: 60px;
	}

	/* UI Mockup */
	.hero-image-placeholder {
		margin-top: 40px;
		perspective: 1000px;
	}

	.ui-mockup {
		background: #ffffff;
		border-radius: 20px;
		box-shadow: 0 40px 100px rgba(0,0,0,0.1);
		border: 1px solid rgba(0,0,0,0.05);
		overflow: hidden;
		max-width: 900px;
		margin: 0 auto;
		transform: rotateX(5deg);
		transition: transform 0.5s ease;
	}

	.ui-mockup:hover {
		transform: rotateX(0deg);
	}

	.mockup-header {
		background: #f5f5f7;
		padding: 12px 20px;
		display: flex;
		align-items: center;
		gap: 20px;
	}

	.dots {
		display: flex;
		gap: 6px;
	}

	.dots span {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: #ff5f57;
	}
	.dots span:nth-child(2) { background: #febc2e; }
	.dots span:nth-child(3) { background: #28c840; }

	.mockup-search {
		background: #fff;
		flex-grow: 1;
		border-radius: 6px;
		padding: 4px 12px;
		font-size: 12px;
		text-align: left;
		color: #86868b;
	}

	.mockup-body {
		display: flex;
		height: 400px;
	}

	.mockup-sidebar {
		width: 150px;
		background: #fbfbfd;
		border-right: 1px solid rgba(0,0,0,0.05);
	}

	.mockup-main {
		flex-grow: 1;
		padding: 30px;
		display: flex;
		flex-direction: column;
		gap: 20px;
	}

	.mockup-box {
		background: #f5f5f7;
		border-radius: 8px;
	}

	.mockup-box.big { height: 100px; width: 100%; }
	
	.mockup-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 20px;
	}

	.mockup-box.small { height: 150px; }

	/* Features Section */
	.bg-alt {
		background: #f5f5f7;
		width: 100vw;
		max-width: none;
		margin-left: calc(50% - 50vw);
		margin-right: calc(50% - 50vw);
	}

	.section-header {
		max-width: 800px;
		margin: 0 auto 60px;
	}

	h2 {
		font-size: clamp(32px, 5vw, 56px);
		line-height: 1.1;
		margin-bottom: 20px;
	}

	.features-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 24px;
		padding: 0 20px;
		max-width: 1200px;
		margin: 0 auto;
	}

	/* How it works */
	.steps-container {
		display: flex;
		flex-direction: column;
		gap: 40px;
		max-width: 800px;
		margin: 0 auto;
	}

	.step {
		display: flex;
		gap: 32px;
		align-items: flex-start;
	}

	.step-num {
		font-size: 40px;
		font-weight: 700;
		color: rgb(var(--accent-rgb));
		opacity: 0.3;
	}

	.step-content h3 {
		font-size: 28px;
		margin-bottom: 8px;
	}

	/* Terminal */
	.terminal-mockup {
		background: #1d1d1f;
		border-radius: 12px;
		padding: 20px;
		margin: 40px auto;
		max-width: 600px;
		text-align: left;
		box-shadow: 0 20px 50px rgba(0,0,0,0.2);
	}

	.terminal-body code {
		display: block;
		color: #fff;
		font-family: 'Courier New', Courier, monospace;
		line-height: 1.6;
		font-size: 14px;
	}

	.terminal-body code:first-child { color: #28c840; }

	/* CTA & Footer */
	.cta-section {
		padding: 120px 20px;
	}

	.footer {
		padding: 60px 20px;
		border-top: 1px solid rgba(0,0,0,0.05);
	}

	.footer-container {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.footer-links {
		display: flex;
		gap: 20px;
	}

	.footer-links a {
		color: var(--text-secondary);
		text-decoration: none;
		font-size: 14px;
	}

	@media (max-width: 768px) {
		.footer-container {
			flex-direction: column;
			gap: 20px;
			text-align: center;
		}
		
		.step {
			flex-direction: column;
			gap: 12px;
		}
	}
</style>
