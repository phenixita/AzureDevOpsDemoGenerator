@page "/environment/createproject"
@using Microsoft.AspNetCore.WebUtilities
@inject NavigationManager Navigation

<PageTitle>Create Project - Azure DevOps Demo Generator</PageTitle>

<div class="container py-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-plus-circle"></i> Create Azure DevOps Project
                    </h4>
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger" role="alert">
                            <i class="bi bi-exclamation-triangle"></i> @errorMessage
                        </div>
                    }

                    @if (isCreating)
                    {
                        <div class="text-center py-5">
                            <div class="spinner-border text-primary mb-3" style="width: 3rem; height: 3rem;" role="status">
                                <span class="visually-hidden">Creating project...</span>
                            </div>
                            <h5>Creating your project...</h5>
                            <p class="text-muted">@statusMessage</p>
                            <div class="progress" style="height: 25px;">
                                <div class="progress-bar progress-bar-striped progress-bar-animated" 
                                     role="progressbar" 
                                     style="width: @progress%;" 
                                     aria-valuenow="@progress" 
                                     aria-valuemin="0" 
                                     aria-valuemax="100">
                                    @progress%
                                </div>
                            </div>
                        </div>
                    }
                    else if (isComplete)
                    {
                        <div class="alert alert-success" role="alert">
                            <h4 class="alert-heading">
                                <i class="bi bi-check-circle"></i> Success!
                            </h4>
                            <p>Your Azure DevOps project has been created successfully.</p>
                            <hr>
                            <p class="mb-0">
                                <a href="@projectUrl" class="btn btn-success" target="_blank">
                                    <i class="bi bi-box-arrow-up-right"></i> Open Project
                                </a>
                                <button class="btn btn-primary ms-2" @onclick="CreateAnother">
                                    Create Another Project
                                </button>
                            </p>
                        </div>
                    }
                    else
                    {
                        <form>
                            <div class="mb-3">
                                <label for="organizationName" class="form-label">Organization Name</label>
                                <input type="text" 
                                       class="form-control" 
                                       id="organizationName" 
                                       @bind="organizationName" 
                                       placeholder="your-organization" 
                                       required />
                                <div class="form-text">The name of your Azure DevOps organization</div>
                            </div>

                            <div class="mb-3">
                                <label for="projectName" class="form-label">Project Name</label>
                                <input type="text" 
                                       class="form-control" 
                                       id="projectName" 
                                       @bind="projectName" 
                                       placeholder="My Demo Project" 
                                       required />
                                <div class="form-text">A unique name for your project</div>
                            </div>

                            <div class="mb-3">
                                <label for="templateSelect" class="form-label">Selected Template</label>
                                <input type="text" 
                                       class="form-control" 
                                       id="templateSelect" 
                                       value="@selectedTemplate" 
                                       readonly />
                            </div>

                            <div class="mb-3 form-check">
                                <input type="checkbox" 
                                       class="form-check-input" 
                                       id="makePrivate" 
                                       @bind="isPrivate" />
                                <label class="form-check-label" for="makePrivate">
                                    Make this project private
                                </label>
                            </div>

                            <div class="d-grid gap-2">
                                <button type="button" 
                                        class="btn btn-primary btn-lg" 
                                        @onclick="CreateProjectAsync"
                                        disabled="@(!IsFormValid())">
                                    <i class="bi bi-play-fill"></i> Create Project
                                </button>
                                <button type="button" 
                                        class="btn btn-secondary" 
                                        @onclick="GoBack">
                                    <i class="bi bi-arrow-left"></i> Back to Templates
                                </button>
                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string? selectedTemplate;
    private string organizationName = "";
    private string projectName = "";
    private bool isPrivate = false;
    private bool isCreating = false;
    private bool isComplete = false;
    private string? errorMessage;
    private string statusMessage = "";
    private int progress = 0;
    private string projectUrl = "";

    protected override void OnInitialized()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("template", out var template))
        {
            selectedTemplate = template;
        }
    }

    private bool IsFormValid()
    {
        return !string.IsNullOrWhiteSpace(organizationName) && 
               !string.IsNullOrWhiteSpace(projectName) &&
               !string.IsNullOrWhiteSpace(selectedTemplate);
    }

    private async Task CreateProjectAsync()
    {
        isCreating = true;
        errorMessage = null;
        progress = 0;

        try
        {
            // Simulate project creation process
            statusMessage = "Initializing project...";
            progress = 10;
            await Task.Delay(1000);

            statusMessage = "Creating work items...";
            progress = 30;
            await Task.Delay(1000);

            statusMessage = "Setting up repositories...";
            progress = 50;
            await Task.Delay(1000);

            statusMessage = "Configuring build pipelines...";
            progress = 70;
            await Task.Delay(1000);

            statusMessage = "Finalizing project setup...";
            progress = 90;
            await Task.Delay(1000);

            statusMessage = "Complete!";
            progress = 100;
            await Task.Delay(500);

            projectUrl = $"https://dev.azure.com/{organizationName}/{projectName}";
            isComplete = true;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error creating project: {ex.Message}";
        }
        finally
        {
            isCreating = false;
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/environment/create");
    }

    private void CreateAnother()
    {
        // Reset form
        organizationName = "";
        projectName = "";
        isPrivate = false;
        isComplete = false;
        progress = 0;
        projectUrl = "";
        Navigation.NavigateTo("/environment/create");
    }
}
