@page "/project/create"
@using System.Linq
@using VstsDemoBuilder.Blazor.Models
@using VstsDemoBuilder.Blazor.Services
@using VstsDemoBuilder.Blazor.Session
@inject IHttpContextAccessor HttpContextAccessor
@inject ITemplateCatalogService TemplateCatalogService
@inject IProvisioningService ProvisioningService
@inject NavigationManager NavigationManager

<PageTitle>Create Project</PageTitle>

<main class="entry-shell">
    <section class="entry-card">
        <h1>Create Project</h1>
        
        @if (_showSuccess && !string.IsNullOrEmpty(_trackingId))
        {
            <div class="alert alert-success">
                <h5>Provisioning Started Successfully!</h5>
                <p>Tracking ID: <strong>@_trackingId</strong></p>
                <p>Your project is being created. You can track progress using this ID.</p>
            </div>
        }

        <EditForm EditContext="@_editContext" OnValidSubmit="HandleValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger mb-3" />

            <!-- Template Selection -->
            <div class="mb-3">
                <label class="form-label">Select Template</label>

                @if (_confirmedTemplate is null)
                {
                    <div class="border rounded p-3 bg-light-subtle mb-2">
                        <p class="mb-0 text-secondary">No template selected yet.</p>
                    </div>
                }
                else
                {
                    <div class="border rounded p-3 mb-2">
                        <div class="d-flex align-items-start gap-3">
                            @if (!string.IsNullOrWhiteSpace(_confirmedTemplate.ImageUrl))
                            {
                                <img src="@_confirmedTemplate.ImageUrl" alt="@_confirmedTemplate.Name preview" style="width: 88px; height: 88px; object-fit: cover; border-radius: 0.35rem;" />
                            }
                            <div>
                                <h5 class="mb-1">@_confirmedTemplate.Name</h5>
                                @if (!string.IsNullOrWhiteSpace(_confirmedTemplate.Description))
                                {
                                    <p class="mb-0 text-secondary">@_confirmedTemplate.Description</p>
                                }
                            </div>
                        </div>
                    </div>
                }

                <button type="button" id="template" class="btn btn-outline-primary" @onclick="OpenTemplateSelectionModal">
                    Choose template
                </button>
                <ValidationMessage For="@(() => _formModel.TemplateFolder)" class="text-danger mt-2 d-block" />
            </div>

            @if (!string.IsNullOrWhiteSpace(_infoMessageHtml))
            {
                <div class="alert alert-info" role="status">
                    @((MarkupString)_infoMessageHtml)
                </div>
            }

            <!-- Project Name -->
            <div class="mb-3">
                <label for="projectName" class="form-label">Project Name <span class="text-danger">*</span></label>
                <InputText id="projectName" class="form-control" @bind-Value="_formModel.ProjectName" placeholder="Enter project name" />
                <ValidationMessage For="@(() => _formModel.ProjectName)" class="text-danger" />
            </div>

            <!-- Organization -->
            <div class="mb-3">
                <label for="organization" class="form-label">Select Organization <span class="text-danger">*</span></label>
                <InputSelect id="organization" class="form-select" @bind-Value="_formModel.Organization">
                    <option value="">-- Select Organization --</option>
                    @foreach (var org in _organizations)
                    {
                        <option value="@org">@org</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => _formModel.Organization)" class="text-danger" />
            </div>

            @if (!string.IsNullOrEmpty(_sessionError))
            {
                 <div class="alert alert-warning">
                    @_sessionError
                 </div>
            }

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert alert-danger">
                    @_errorMessage
                </div>
            }

            <!-- Dynamic Parameters Section -->
            @if (_currentTemplateParameters.Count > 0)
            {
                <div class="mb-3">
                    <h5>Template Parameters</h5>
                    @foreach (var param in _currentTemplateParameters)
                    {
                        <div class="mb-3">
                            <label class="form-label">@param.Label</label>
                            <input type="text"
                                   class="form-control"
                                   @bind="_formModel.Parameters[param.FieldName]" />
                        </div>
                    }
                </div>
            }

            <!-- Submit Button -->
            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary" disabled="@_isSubmitting">
                    @if (_isSubmitting)
                    {
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        <span> Creating...</span>
                    }
                    else
                    {
                        <span>Create Project</span>
                    }
                </button>
            </div>
            
            <div class="mt-3 text-center">
                 <a class="text-secondary text-decoration-none" href="/auth/signout">Sign out</a>
            </div>

        </EditForm>
    </section>
</main>

<TemplateSelectionModal
    IsOpen="@_isModalOpen"
    Groups="@_templateGroups"
    PendingSelection="@_pendingTemplate"
    OnClose="HandleTemplateModalCloseAsync"
    OnTemplateClicked="HandleTemplateClickedAsync"
    OnConfirm="HandleTemplateConfirmedAsync" />

@code {
    private ProjectCreateFormModel _formModel = new();
    private EditContext _editContext = null!;
    private List<string> _organizations = [];
    private List<TemplateCatalogGroup> _templateGroups = [];
    private List<TemplateParameterDefinition> _currentTemplateParameters = [];
    private bool _isSubmitting = false;
    private string? _trackingId;
    private string? _sessionError;
    private bool _showSuccess = false;
    private string? _errorMessage;
    private bool _isModalOpen;
    private TemplateCatalogItem? _pendingTemplate;
    private TemplateCatalogItem? _confirmedTemplate;
    private string? _infoMessageHtml;

    protected override void OnInitialized()
    {
        _editContext = new EditContext(_formModel);
    }

    protected override async Task OnInitializedAsync()
    {
        // Load Organizations from session
        if (HttpContextAccessor.HttpContext?.Session != null)
        {
            var orgs = HttpContextAccessor.HttpContext.Session.GetStringList(SessionKeys.Organizations) ?? [];
            _organizations = orgs.ToList();
            if (_organizations.Count == 0)
            {
                _sessionError = "No organizations found in session. Please sign in again.";
            }
        }

        _templateGroups = await TemplateCatalogService.GetTemplateGroupsAsync();
    }

    private void OpenTemplateSelectionModal()
    {
        _pendingTemplate = _confirmedTemplate ?? _templateGroups.SelectMany(group => group.Templates).FirstOrDefault();
        UpdatePendingTemplateFields(_pendingTemplate);
        _isModalOpen = true;
    }

    private Task HandleTemplateClickedAsync(TemplateCatalogItem template)
    {
        _pendingTemplate = template;
        UpdatePendingTemplateFields(template);
        return Task.CompletedTask;
    }

    private Task HandleTemplateModalCloseAsync()
    {
        _isModalOpen = false;
        return Task.CompletedTask;
    }

    private async Task HandleTemplateConfirmedAsync(TemplateCatalogItem template)
    {
        var templateChanged = !string.Equals(_confirmedTemplate?.TemplateFolder, template.TemplateFolder, StringComparison.OrdinalIgnoreCase);

        if (templateChanged)
        {
            ResetDependentState();
        }

        _confirmedTemplate = template;
        _pendingTemplate = template;
        _formModel.TemplateFolder = template.TemplateFolder;
        _formModel.TemplateName = template.Name;
        _formModel.TemplateDescription = template.Description;
        _formModel.TemplateImageUrl = template.ImageUrl;
        _infoMessageHtml = string.IsNullOrWhiteSpace(template.MessageHtml) ? null : template.MessageHtml;
        UpdatePendingTemplateFields(template);
        _editContext.NotifyFieldChanged(FieldIdentifier.Create(() => _formModel.TemplateFolder));

        _currentTemplateParameters = await TemplateCatalogService.GetTemplateParametersAsync(template.TemplateFolder);
        foreach (var param in _currentTemplateParameters)
        {
            if (templateChanged || !_formModel.Parameters.ContainsKey(param.FieldName))
            {
                _formModel.Parameters[param.FieldName] = string.Empty;
            }
        }

        _isModalOpen = false;
    }

    private void ResetDependentState()
    {
        _currentTemplateParameters.Clear();
        _formModel.Parameters.Clear();
        _errorMessage = null;
        _showSuccess = false;
        _trackingId = null;
        ResetValidationState();
    }

    private void ResetValidationState()
    {
        _editContext = new EditContext(_formModel);
    }

    private void UpdatePendingTemplateFields(TemplateCatalogItem? template)
    {
        if (template is null)
        {
            _formModel.PendingTemplateFolder = null;
            _formModel.PendingTemplateName = null;
            _formModel.PendingTemplateDescription = null;
            _formModel.PendingTemplateImageUrl = null;
            return;
        }

        _formModel.PendingTemplateFolder = template.TemplateFolder;
        _formModel.PendingTemplateName = template.Name;
        _formModel.PendingTemplateDescription = template.Description;
        _formModel.PendingTemplateImageUrl = template.ImageUrl;
    }

    private async Task HandleValidSubmit()
    {
        _isSubmitting = true;
        _errorMessage = null;
        _showSuccess = false;

        try
        {
            var session = HttpContextAccessor.HttpContext?.Session;
            if (session is null)
            {
                _errorMessage = "Session not available. Please sign in again.";
                return;
            }

            var email = session.GetEmail() ?? string.Empty;
            var accessToken = session.GetAccessToken();
            var userId = session.GetUserId() ?? email;

            if (string.IsNullOrWhiteSpace(accessToken))
            {
                _errorMessage = "Session expired. Please sign in again.";
                return;
            }

            if (!ValidateDynamicParameters())
            {
                return;
            }

            _trackingId = await ProvisioningService.StartProjectProvisioningAsync(
                _formModel,
                userId,
                email,
                accessToken);

            _showSuccess = true;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to start provisioning: {ex.Message}";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private bool ValidateDynamicParameters()
    {
        if (!_currentTemplateParameters.Any())
        {
            return true;
        }

        foreach (var param in _currentTemplateParameters)
        {
            if (!_formModel.Parameters.ContainsKey(param.FieldName) ||
                string.IsNullOrWhiteSpace(_formModel.Parameters[param.FieldName]))
            {
                _errorMessage = $"Please fill in all template parameters: {param.Label}";
                return false;
            }
        }

        return true;
    }
}
