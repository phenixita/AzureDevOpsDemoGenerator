@page "/extractor"
@page "/extractor/index"

<PageTitle>Template Extractor - Azure DevOps Demo Generator</PageTitle>

<div class="container py-4">
    <div class="row">
        <div class="col-12">
            <h2>
                <i class="bi bi-download"></i> Template Extractor
            </h2>
            <p class="lead">Extract configuration from existing Azure DevOps projects to create custom templates</p>
            <hr />
        </div>
    </div>

    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card shadow">
                <div class="card-body">
                    <div class="alert alert-info mb-4">
                        <h5 class="alert-heading">
                            <i class="bi bi-info-circle"></i> How it works
                        </h5>
                        <p>The Template Extractor allows you to:</p>
                        <ul class="mb-0">
                            <li>Export configuration from your existing Azure DevOps projects</li>
                            <li>Create reusable templates for the Demo Generator</li>
                            <li>Share templates with your team</li>
                        </ul>
                    </div>

                    <form>
                        <div class="mb-3">
                            <label for="accountName" class="form-label">Account Name</label>
                            <input type="text" class="form-control" id="accountName" placeholder="your-organization" required />
                        </div>

                        <div class="mb-3">
                            <label for="projectName" class="form-label">Project Name</label>
                            <input type="text" class="form-control" id="projectName" placeholder="Project to extract" required />
                        </div>

                        <div class="d-grid">
                            <button type="button" class="btn btn-primary btn-lg">
                                <i class="bi bi-play-fill"></i> Start Extraction
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
